###
# Get member by ID
GET http://localhost:8080/api/v1/members/69e100da9359b4be784078df

###
# List subscriptions by member ID
GET http://localhost:8080/api/v1/members/69dfa3af8f14bfa54ed2509d/subscriptions

###
# Activate member after offline payment confirmation
PATCH http://localhost:8080/api/v1/members/69dfa3af8f14bfa54ed2509d/activate
Content-Type: application/json

{
  "subscription_id": "69f20b22f79bb78cac99aa0a"
}

###
# Create subscription
POST http://localhost:8080/api/v1/subscriptions
Content-Type: application/json

{
  "member_id": "69dfa3af8f14bfa54ed2509d",
  "course_id": "69f20a180c4cd4cdf57684fd",
  "home_branch_id": "69f20a180c4cd4cdf57684fe",
  "start_date": "2026-04-28T10:00:00Z",
  "end_date": "2026-05-28T10:00:00Z",
  "session_per_week": 3,
  "discount_type": "percent",
  "discount_value": 10,
  "promo_code": "SUMMER10"
}

###
# Get subscription by ID
GET http://localhost:8080/api/v1/subscriptions/69f20b22f79bb78cac99aa0a

###
# Suspend subscription
PATCH http://localhost:8080/api/v1/subscriptions/69f20b22f79bb78cac99aa0a/suspend
Content-Type: application/json

{
  "start_date": "2026-05-05T09:00:00Z",
  "end_date": "2026-05-20T09:00:00Z",
  "frozen_session": 4,
  "reason": "Business trip"
}

###
# Resume subscription
PATCH http://localhost:8080/api/v1/subscriptions/69f20b22f79bb78cac99aa0a/unsuspend

###
# Expire subscription manually
PATCH http://localhost:8080/api/v1/subscriptions/69f20b22f79bb78cac99aa0a/expire

###
# Refund subscription
POST http://localhost:8080/api/v1/subscriptions/69f20b22f79bb78cac99aa0a/refund
Content-Type: application/json

{
  "reason": "member requested cancellation"
}

