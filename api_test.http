@baseUrl = http://localhost:8080
@access_token = paste_access_token_here
@refresh_token = paste_refresh_token_here
@restricted_access_token = paste_receptionist_or_trainer_access_token_here

# Deterministic IDs for a fresh database seeded by `go run ./cmd/seed`.
# If your DB already had matching demo records with different IDs, use list/get endpoints to refresh
# these values.
@demo_trainer_employee_id = 665000000000000000000004
@demo_branch_central_id = 665000000000000000000101
@demo_course_basic_id = 665000000000000000000201
@demo_member_active_id = 665000000000000000000301
@demo_member_pending_id = 665000000000000000000303
@demo_subscription_active_id = 665000000000000000000401
@demo_subscription_pending_id = 665000000000000000000403

# Health check
GET {{baseUrl}}/ping

###

# Login
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "admin@gym.test",
  "password": "demo123456"
}

###

# Current employee
GET {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{access_token}}

###

# Refresh token
POST {{baseUrl}}/api/v1/auth/refresh
Content-Type: application/json

{
  "refresh_token": "{{refresh_token}}"
}

###

# Logout
POST {{baseUrl}}/api/v1/auth/logout
Content-Type: application/json

{
  "refresh_token": "{{refresh_token}}"
}

###

# Missing access token should return 401
GET {{baseUrl}}/api/v1/courses

###

# Invalid access token should return 401 with error.code = UNAUTHORIZED
GET {{baseUrl}}/api/v1/courses
Authorization: Bearer invalid-token

###

# Forbidden role should return 403 when token role cannot manage courses
POST {{baseUrl}}/api/v1/courses
Content-Type: application/json
Authorization: Bearer {{restricted_access_token}}

{
  "title": "Role Guard Test",
  "level": "basic",
  "base_price": 100000,
  "session_count": 10,
  "description": "Should be rejected for non-admin/manager roles"
}

###

# Dashboard summary - admin/manager only
GET {{baseUrl}}/api/v1/dashboard/summary?branch_id={{demo_branch_central_id}}&from=2026-06-01T00:00:00Z&to=2026-06-30T23:59:59Z
Authorization: Bearer {{access_token}}

###

# Dashboard revenue buckets - admin/manager only
GET {{baseUrl}}/api/v1/dashboard/revenue?branch_id={{demo_branch_central_id}}&from=2026-06-01T00:00:00Z&to=2026-06-30T23:59:59Z&bucket=day
Authorization: Bearer {{access_token}}

###

# Dashboard plan distribution - admin/manager only
GET {{baseUrl}}/api/v1/dashboard/plans?branch_id={{demo_branch_central_id}}
Authorization: Bearer {{access_token}}

###

# Dashboard recent members - admin/manager only
GET {{baseUrl}}/api/v1/dashboard/members/recent?limit=5
Authorization: Bearer {{access_token}}

###

# Dashboard today's sessions - admin/manager only
GET {{baseUrl}}/api/v1/dashboard/sessions/today?branch_id={{demo_branch_central_id}}&date=2026-06-04T00:00:00Z
Authorization: Bearer {{access_token}}

###

# Dashboard forbidden role should return 403 for receptionist/trainer token
GET {{baseUrl}}/api/v1/dashboard/summary
Authorization: Bearer {{restricted_access_token}}

###

# Dashboard invalid date range should return 400 with error.code = INVALID_DATE
GET {{baseUrl}}/api/v1/dashboard/summary?from=2026-06-30T00:00:00Z&to=2026-06-01T00:00:00Z
Authorization: Bearer {{access_token}}

###

# Create employee - admin only
POST {{baseUrl}}/api/v1/employees
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "employee_id": "EMP-SAMPLE-001",
  "full_name": "Sample Trainer",
  "email": "sample.trainer@gym.test",
  "password": "strong-password-123",
  "role": ["trainer"],
  "level": "advanced",
  "phone": "0900000002",
  "branch_id": ["{{demo_branch_central_id}}"],
  "status": "active"
}

###

# List employees
GET {{baseUrl}}/api/v1/employees?role=trainer&status=active&branch_id={{demo_branch_central_id}}
Authorization: Bearer {{access_token}}

###

# Get employee by ID
GET {{baseUrl}}/api/v1/employees/{{demo_trainer_employee_id}}
Authorization: Bearer {{access_token}}

###

# Update employee
PATCH {{baseUrl}}/api/v1/employees/{{demo_trainer_employee_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "full_name": "Tran Van Trainer Updated",
  "role": ["trainer", "manager"],
  "level": "professional",
  "phone": "0900000003"
}

###

# Reset employee password
PATCH {{baseUrl}}/api/v1/employees/{{demo_trainer_employee_id}}/password
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "password": "new-strong-password-123"
}

###

# Login with created employee
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "sample.trainer@gym.test",
  "password": "new-strong-password-123"
}

###

# Non-admin employee management should return 403
GET {{baseUrl}}/api/v1/employees
Authorization: Bearer {{restricted_access_token}}

###

# Invalid employee ID should return 400 with error.code = INVALID_ID
GET {{baseUrl}}/api/v1/employees/not-an-object-id
Authorization: Bearer {{access_token}}

###

# Invalid employee body should return 400 with error.code = INVALID_INPUT and no raw bind error
POST {{baseUrl}}/api/v1/employees
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "employee_id": 123
}

###

# Member registration
POST {{baseUrl}}/api/v1/members
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "ccid": "012345678901",
  "full_name": "Nguyen Van A",
  "email": "a@example.com",
  "phone": "0900000000",
  "gender": "male",
  "level": "basic"
}

###

# Member registration 2
POST {{baseUrl}}/api/v1/members
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "ccid": "012345678902",
  "full_name": "Tran Thi B",
  "email": "b@example.com",
  "phone": "0900000001",
  "gender": "female",
  "level": "advanced"
}

###
# Get member by ID
GET {{baseUrl}}/api/v1/members/{{demo_member_active_id}}
Authorization: Bearer {{access_token}}

###
# List subscriptions by member ID
GET {{baseUrl}}/api/v1/members/{{demo_member_pending_id}}/subscriptions
Authorization: Bearer {{access_token}}

###
# Activate member after offline payment confirmation
PATCH {{baseUrl}}/api/v1/members/{{demo_member_pending_id}}/activate
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "subscription_id": "{{demo_subscription_pending_id}}"
}

###
# Create subscription
POST {{baseUrl}}/api/v1/subscriptions
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "member_id": "{{demo_member_pending_id}}",
  "course_id": "{{demo_course_basic_id}}",
  "home_branch_id": "{{demo_branch_central_id}}",
  "start_date": "2026-04-28T10:00:00Z",
  "end_date": "2026-05-28T10:00:00Z",
  "session_per_week": 3,
  "discount_type": "percent",
  "discount_value": 10,
  "promo_code": "SUMMER10"
}

###
# Get subscription by ID
GET {{baseUrl}}/api/v1/subscriptions/{{demo_subscription_active_id}}
Authorization: Bearer {{access_token}}

###
# Suspend subscription
PATCH {{baseUrl}}/api/v1/subscriptions/{{demo_subscription_active_id}}/suspend
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "start_date": "2026-05-05T09:00:00Z",
  "end_date": "2026-05-20T09:00:00Z",
  "frozen_session": 4,
  "reason": "Business trip"
}

###

# Invalid subscription date should return 400 with error.code = INVALID_DATE
PATCH {{baseUrl}}/api/v1/subscriptions/{{demo_subscription_active_id}}/suspend
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "start_date": "not-a-date",
  "end_date": "2026-05-20T09:00:00Z",
  "frozen_session": 4,
  "reason": "Bad date sample"
}

###

# Resume subscription
PATCH {{baseUrl}}/api/v1/subscriptions/{{demo_subscription_active_id}}/unsuspend
Authorization: Bearer {{access_token}}

###
# Expire subscription manually
PATCH {{baseUrl}}/api/v1/subscriptions/{{demo_subscription_active_id}}/expire
Authorization: Bearer {{access_token}}

###
# Refund subscription
POST {{baseUrl}}/api/v1/subscriptions/{{demo_subscription_active_id}}/refund
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "reason": "member requested cancellation"
}

###
# Create course
POST {{baseUrl}}/api/v1/courses
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "title": "Yoga for Beginners",
  "level": "basic",
  "base_price": 180000,
  "session_count": 12,
  "description": "Beginner yoga course"
}

###
# List courses
GET {{baseUrl}}/api/v1/courses
Authorization: Bearer {{access_token}}

###
# Get course by ID
GET {{baseUrl}}/api/v1/courses/{{demo_course_basic_id}}
Authorization: Bearer {{access_token}}

###
# Update course
PATCH {{baseUrl}}/api/v1/courses/{{demo_course_basic_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "title": "Yoga for Beginners - Updated",
  "level": "basic",
  "base_price": 200000,
  "session_count": 14,
  "description": "Updated beginner yoga course"
}

###
# Delete course
DELETE {{baseUrl}}/api/v1/courses/{{demo_course_basic_id}}
Authorization: Bearer {{access_token}}

###
# Create branch
POST {{baseUrl}}/api/v1/branches
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "branch_code": "HCM01",
  "name": "Ho Chi Minh Main Branch",
  "address": "123 Nguyen Hue, District 1",
  "province": "Ho Chi Minh",
  "location": {
    "type": "Point",
    "coordinates": [106.7009, 10.7769]
  },
  "manager_id": ""
}

###
# List branches
GET {{baseUrl}}/api/v1/branches
Authorization: Bearer {{access_token}}

###
# Nearby branches
GET {{baseUrl}}/api/v1/branches/nearby?lng=106.7001&lat=10.8001&max_distance=5000&limit=10
Authorization: Bearer {{access_token}}

###
# Nearby branches with defaults
GET {{baseUrl}}/api/v1/branches/nearby?lng=106.7001&lat=10.8001
Authorization: Bearer {{access_token}}

###
# Nearby branches invalid max_distance
GET {{baseUrl}}/api/v1/branches/nearby?lng=106.7001&lat=10.8001&max_distance=0
Authorization: Bearer {{access_token}}

###
# Get branch by ID
GET {{baseUrl}}/api/v1/branches/{{demo_branch_central_id}}
Authorization: Bearer {{access_token}}

###
# Update branch
PATCH {{baseUrl}}/api/v1/branches/{{demo_branch_central_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "branch_code": "HCM01",
  "name": "Ho Chi Minh Main Branch - Updated",
  "address": "123 Nguyen Hue, District 1",
  "province": "Ho Chi Minh",
  "location": {
    "type": "Point",
    "coordinates": [106.7009, 10.7769]
  },
  "manager_id": ""
}

###

# Duplicate branch_code should return 409 with error.code = CONFLICT
POST {{baseUrl}}/api/v1/branches
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "branch_code": "HCM01",
  "name": "Duplicate Branch Code",
  "address": "456 Nguyen Hue, District 1",
  "province": "Ho Chi Minh",
  "location": {
    "type": "Point",
    "coordinates": [106.7010, 10.7770]
  }
}

###

# Delete branch
DELETE {{baseUrl}}/api/v1/branches/{{demo_branch_central_id}}
Authorization: Bearer {{access_token}}

###
# Attendance check-in
POST {{baseUrl}}/api/v1/attendance/checkin
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "subscription_id": "{{demo_subscription_active_id}}",
  "branch_id": "{{demo_branch_central_id}}",
  "date": "2026-05-10T08:00:00Z",
  "status": "attended"
}

###
# Report missed attendance
POST {{baseUrl}}/api/v1/attendance/report
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "subscription_id": "{{demo_subscription_active_id}}",
  "branch_id": "{{demo_branch_central_id}}",
  "date": "2026-05-12T08:00:00Z"
}

###
# Makeup attendance for reported missed date
POST {{baseUrl}}/api/v1/attendance/makeup
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "subscription_id": "{{demo_subscription_active_id}}",
  "branch_id": "{{demo_branch_central_id}}",
  "date": "2026-05-14T08:00:00Z",
  "is_makeup_for": "2026-05-12T08:00:00Z"
}

###
# List attendance by subscription
GET {{baseUrl}}/api/v1/subscriptions/{{demo_subscription_active_id}}/attendance
Authorization: Bearer {{access_token}}
